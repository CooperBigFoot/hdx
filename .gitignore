/target
*.swp
*.swo
.DS_Store
Thumbs.db

# Session orchestration tooling (saved dynamic workflow scripts), not project source
.claude/workflows/

# Conformance fixture generator: dev-only Python harness artifacts (not source).
conformance/generator/.venv/
conformance/generator/**/__pycache__/
conformance/generator/.lock.sha256
conformance/generator/scratch/
**/__pycache__/
*.py[cod]

# PyO3 binding (crates/python) build/test artifacts: the dedicated binding venv
# (MS9-S3 creates it via `maturin develop`), bytecode caches, and the maturin wheel
# output dir. None of these are source; mirrors the conformance generator's
# venv-ignore discipline so no venv/wheel artifact is ever committed.
crates/python/.venv/
crates/python/**/__pycache__/
target/wheels/

# Generated conformance fixture DATA is NOT tracked — it is regenerated from the
# committed deterministic generator (run conformance/generator/regenerate.sh
# before `cargo test`). Nothing under these two trees is tracked: the goldens now
# live in the tracked, never-ignored conformance/goldens/ directory (outside these
# trees, so regenerate.sh — which rmtrees them — can never clobber a golden). The
# generator source + conformance/README + conformance/goldens/ remain tracked (they
# live outside these two trees and need no rule).
conformance/valid/**
conformance/invalid/**
